# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values for your
# local environment. Never commit .env to Git.
# ============================================================

# Server
# PORT: the port Express listens on
PORT=3333

# FRONTEND_URL: the origin allowed by CORS
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Email (Nodemailer + Gmail SMTP)
# GMAIL_USER: the Gmail address used to send emails
GMAIL_USER=your-gmail-address@gmail.com

# GMAIL_APP_PASSWORD: a Gmail App Password (NOT your
# account password). Generate one at:
# https://myaccount.google.com/apppasswords
# Must be 16 characters, no spaces.
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Storage
# DATA_DIR: path to the folder where JSON data files
# are stored. Use ./data for local development.
# On Railway, set this to an absolute path pointing
# to the persistent volume mount.
DATA_DIR=./data
