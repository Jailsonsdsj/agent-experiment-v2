{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "jsx": "react",
    "outDir": "./dist-test"
  },
  "include": [
    "features/**/*.ts",
    "src/**/*.ts"
  ]
}
